# Telegram Bot Configuration
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
ADMIN_IDS=123456789,987654321

# Database Configuration (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/adolat_ai_bot
# For local run without docker, change db to localhost
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/adolat_ai_bot

# Redis Configuration (For FSM, Rate Limiting and Caching)
REDIS_URL=redis://redis:6379/0
# For local run without docker, change redis to localhost
# REDIS_URL=redis://localhost:6379/0

# Gemini API Configuration
GEMINI_API_KEY=AIzaSyYourRealGeminiKeyHere
GEMINI_MODEL=gemini-1.5-pro
# Models: gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash-exp

# Payment Integrations (Click, Payme, Mock)
PAYMENT_MODE=mock
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# File Limits
MAX_FREE_FILE_SIZE_MB=1

# App Environment & Webhook Settings
APP_ENV=development
WEBHOOK_URL=https://your-domain.uz/webhook
LOG_LEVEL=INFO
